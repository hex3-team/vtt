{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "noImplicitOverride": true,
    "module": "esnext",
    "target": "es2022",
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "moduleResolution": "bundler",
    "outDir": "./build",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}